<UserControl x:Class="WPF.OrderManagement.Shared.WizardSummary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF.OrderManagement.Shared"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             Name="SummaryUserControl"
             Margin="5,0,5,5">
    <StackPanel>
        <TextBlock Name="tHeader"
                   FontWeight="Bold"
                   Margin="0,0,0,5"
                   Text="{Binding Path=Header, ElementName=SummaryUserControl,StringFormat={}{0}:}" />
        <TextBlock Name="tInfo"
                   Text="{Binding Path=Info,ElementName=SummaryUserControl}" />
        <Separator />
    </StackPanel>
</UserControl>
